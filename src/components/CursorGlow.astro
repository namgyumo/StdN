---
// 마우스 주변에 네온 라임 radial glow를 따라다니게 함. 모바일에서는 숨김.
---

<div class="cursor-glow" id="cursor-glow" aria-hidden="true"></div>

<script>
  // astro page transition 간에도 동작하도록 global listener 한 번만 설치
  declare global {
    interface Window {
      __cursorGlowInited?: boolean;
    }
  }

  function init() {
    if (window.__cursorGlowInited) return;
    const el = document.getElementById('cursor-glow');
    if (!el) return;

    if (window.matchMedia('(max-width: 768px)').matches) {
      el.remove();
      return;
    }
    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
      el.remove();
      return;
    }

    window.__cursorGlowInited = true;

    let mouseX = 0;
    let mouseY = 0;
    let pending = false;
    let active = false;

    function paint() {
      pending = false;
      // -260 = -width/2 (520/2) → 원 중심을 마우스에 정확히 맞춤
      el.style.transform = `translate3d(${mouseX - 260}px, ${mouseY - 260}px, 0)`;
    }

    window.addEventListener('mousemove', (e) => {
      mouseX = e.clientX;
      mouseY = e.clientY;
      if (!active) {
        active = true;
        el.classList.add('active');
      }
      if (!pending) {
        pending = true;
        requestAnimationFrame(paint);
      }
    }, { passive: true });

    window.addEventListener('mouseleave', () => {
      active = false;
      el.classList.remove('active');
    });
  }

  init();
  document.addEventListener('astro:after-swap', init);
</script>
