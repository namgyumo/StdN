---
import BaseLayout from '@layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const projects = (await getCollection('projects')).sort(
  (a, b) =>
    (b.data.order ?? 0) - (a.data.order ?? 0) ||
    b.data.startedAt.valueOf() - a.data.startedAt.valueOf(),
);

const featured = projects.filter((p) => p.data.featured);
const others = projects.filter((p) => !p.data.featured);

const statusLabel: Record<string, string> = {
  active: 'ACTIVE',
  wip: 'WIP',
  done: 'DONE',
  idea: 'IDEA',
};

const yearRange = (start: Date, end?: Date) => {
  const s = start.getFullYear();
  if (!end) return `${s} —`;
  const e = end.getFullYear();
  return s === e ? `${s}` : `${s}–${e}`;
};
---

<BaseLayout
  title="Projects"
  description="std::N 이 만들고 있거나 만들었던 프로젝트 모음."
>
  <section class="container container-narrow" style="padding-top: 60px;">
    <header class="center" style="margin-bottom: 40px;">
      <p class="eyebrow">// projects</p>
      <h1 class="h1">Projects</h1>
      <p style="color: var(--color-fg-dim); font-family: var(--font-mono);">
        만들고 있는 것과, 만들었던 것.
      </p>
    </header>

    {featured.length > 0 && (
      <>
        <h2 class="section-h1" style="margin-top: 40px;">Featured</h2>
        <div class="project-grid">
          {featured.map((p) => (
            <a class="project-card" href={`/projects/${p.id}`} aria-label={`${p.data.title} 자세히 보기`}>
              <div class="card-top">
                <span class={`status-pill status-${p.data.status}`}>{statusLabel[p.data.status]}</span>
                <span class="card-year">{yearRange(p.data.startedAt, p.data.finishedAt)}</span>
              </div>
              <h3>{p.data.title}</h3>
              <p>{p.data.summary}</p>
              <div class="project-stack">
                {p.data.stack.slice(0, 5).map((s) => <span>{s}</span>)}
                {p.data.stack.length > 5 && <span>+{p.data.stack.length - 5}</span>}
              </div>
            </a>
          ))}
        </div>
      </>
    )}

    {others.length > 0 && (
      <>
        <h2 class="section-h1" style="margin-top: 60px;">Other</h2>
        <div class="project-grid">
          {others.map((p) => (
            <a class="project-card" href={`/projects/${p.id}`} aria-label={`${p.data.title} 자세히 보기`}>
              <div class="card-top">
                <span class={`status-pill status-${p.data.status}`}>{statusLabel[p.data.status]}</span>
                <span class="card-year">{yearRange(p.data.startedAt, p.data.finishedAt)}</span>
              </div>
              <h3>{p.data.title}</h3>
              <p>{p.data.summary}</p>
              <div class="project-stack">
                {p.data.stack.slice(0, 5).map((s) => <span>{s}</span>)}
                {p.data.stack.length > 5 && <span>+{p.data.stack.length - 5}</span>}
              </div>
            </a>
          ))}
        </div>
      </>
    )}

    {projects.length === 0 && (
      <p style="text-align:center; padding: 60px 20px; color: var(--color-fg-dim); font-family: var(--font-mono);">
        아직 공개된 프로젝트가 없습니다. <code>src/content/projects/</code> 에 추가하세요.
      </p>
    )}
  </section>
</BaseLayout>

<style>
  .card-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 10px;
    margin-bottom: 10px;
  }
  .card-year {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--color-fg-dim);
  }
  .status-pill {
    display: inline-block;
    padding: 2px 9px;
    border: 1px solid rgba(193, 255, 0, 0.4);
    border-radius: 999px;
    font-family: var(--font-mono);
    font-size: 0.65rem;
    letter-spacing: 2px;
    color: var(--color-accent);
    background: rgba(193, 255, 0, 0.05);
  }
  .status-pill.status-done {
    border-color: rgba(160, 160, 160, 0.4);
    color: #a0a0a0;
    background: rgba(160, 160, 160, 0.05);
  }
  .status-pill.status-idea {
    border-color: rgba(180, 140, 255, 0.4);
    color: #b48cff;
    background: rgba(180, 140, 255, 0.05);
  }
</style>
