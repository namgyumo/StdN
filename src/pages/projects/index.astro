---
import BaseLayout from '@layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const projects = (await getCollection('projects')).sort(
  (a, b) => (b.data.order ?? 0) - (a.data.order ?? 0) || b.data.startedAt.valueOf() - a.data.startedAt.valueOf(),
);

const featured = projects.filter((p) => p.data.featured);
const others = projects.filter((p) => !p.data.featured);

const statusLabel: Record<string, string> = {
  active: 'ACTIVE',
  wip: 'WIP',
  done: 'DONE',
  idea: 'IDEA',
};
---

<BaseLayout
  title="Projects"
  description="std::N 이 만들고 있거나 만들었던 프로젝트 모음."
>
  <section class="container container-narrow" style="padding-top: 60px;">
    <header class="center" style="margin-bottom: 40px;">
      <p class="eyebrow">// projects</p>
      <h1 class="h1">Projects</h1>
      <p style="color: var(--color-fg-dim); font-family: var(--font-mono);">
        만들고 있는 것과, 만들었던 것.
      </p>
    </header>

    {featured.length > 0 && (
      <>
        <h2 class="section-h1" style="margin-top: 40px;">Featured</h2>
        <div class="project-grid">
          {featured.map((p) => (
            <a class="project-card" href={`/projects/${p.id}`}>
              <div style="display:flex; align-items:center; justify-content:space-between; gap:10px; margin-bottom: 6px;">
                <span class="tag">{statusLabel[p.data.status]}</span>
                <span style="font-family: var(--font-mono); font-size: .75rem; color: var(--color-fg-dim);">
                  {p.data.startedAt.getFullYear()}
                </span>
              </div>
              <h3>{p.data.title}</h3>
              <p>{p.data.summary}</p>
              <div class="project-stack">
                {p.data.stack.map((s) => <span>{s}</span>)}
              </div>
            </a>
          ))}
        </div>
      </>
    )}

    {others.length > 0 && (
      <>
        <h2 class="section-h1" style="margin-top: 60px;">Other</h2>
        <div class="project-grid">
          {others.map((p) => (
            <a class="project-card" href={`/projects/${p.id}`}>
              <div style="display:flex; align-items:center; justify-content:space-between; gap:10px; margin-bottom: 6px;">
                <span class="tag">{statusLabel[p.data.status]}</span>
                <span style="font-family: var(--font-mono); font-size: .75rem; color: var(--color-fg-dim);">
                  {p.data.startedAt.getFullYear()}
                </span>
              </div>
              <h3>{p.data.title}</h3>
              <p>{p.data.summary}</p>
              <div class="project-stack">
                {p.data.stack.map((s) => <span>{s}</span>)}
              </div>
            </a>
          ))}
        </div>
      </>
    )}

    {projects.length === 0 && (
      <p style="text-align:center; padding: 60px 20px; color: var(--color-fg-dim); font-family: var(--font-mono);">
        아직 공개된 프로젝트가 없습니다. <code>src/content/projects/</code> 에 추가하세요.
      </p>
    )}
  </section>
</BaseLayout>
