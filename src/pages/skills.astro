---
import BaseLayout from '@layouts/BaseLayout.astro';
import BojWidget from '@components/BojWidget.astro';

const skills = [
  {
    icon: '[ C / C++ ]',
    name: 'Low-level & Memory',
    desc: '포인터를 활용한 직접적인 메모리 제어 및 시스템 아키텍처 이해. 메모리 누수 방지와 자원 최적화에 익숙합니다.',
  },
  {
    icon: '[ ALGORITHM ]',
    name: 'Data Structure & PS',
    desc: '시간/공간 복잡도를 고려한 알고리즘 설계. 최적의 로직으로 병목 현상을 해결하는 것을 즐깁니다.',
  },
  {
    icon: '[ WEB_UI ]',
    name: 'Frontend Development',
    desc: 'HTML/CSS를 활용한 반응형 웹 설계 및 시각적 인터랙션 구현. Astro·TypeScript로 정적·동적 웹을 다룹니다.',
  },
  {
    icon: '[ EDGE_RUNTIME ]',
    name: 'Cloudflare Stack',
    desc: 'Cloudflare Pages/Workers/D1/R2 위에서 배포·운영하는 풀 에지 아키텍처에 관심이 있습니다.',
  },
];

const records = [
  { date: '25.06.13', text: '교내 DoD 알고리즘 대회 우수상' },
  { date: '25.09.09', text: 'U-BDIA 코딩 테스트 참여' },
  { date: '25.09.11', text: 'GDGoC-DEU 멤버 참여' },
  { date: '25.10.11', text: 'ICPC 대회 참여' },
  { date: '26.02.20', text: 'GDGoC-DEU 코어 멤버 참여' },
  { date: '26.02.21', text: 'solved.ac Gold-V 달성' },
];
---

<BaseLayout
  title="Skills"
  description="std::N 이 다루는 기술과 지금까지 참여한 활동 기록."
>
  <section class="skills-hero">
    <h1 class="h1">Skills &amp; Experience</h1>
    <p class="section-sub">기술 및 역량</p>
  </section>

  <section class="container">
    <div class="skills-layout">
      <div>
        <h2 class="section-h1">SKILLS 기술</h2>
        {skills.map((s) => (
          <article class="skill-card">
            <div class="skill-icon">{s.icon}</div>
            <h3 class="skill-name">{s.name}</h3>
            <p class="skill-desc">{s.desc}</p>
          </article>
        ))}
      </div>

      <div>
        <h2 class="section-h1">RECORDS 활동</h2>
        <ol class="records" style="margin-top: 40px;">
          {records.map((r) => (
            <li class="record">
              <time class="port-date" datetime={`20${r.date.replace(/\./g, '-')}`}>{r.date}</time>
              <div class="port-inner">{r.text}</div>
            </li>
          ))}
        </ol>
      </div>
    </div>

    <BojWidget />
  </section>
</BaseLayout>

<style>
  .skills-hero {
    text-align: center;
    padding: 40px 20px 0;
  }
  .skills-hero .h1 {
    display: inline-block;
  }
  .section-sub {
    margin-top: 10px;
    font-family: var(--font-mono);
    color: var(--color-fg-dim);
    letter-spacing: 3px;
  }
</style>
