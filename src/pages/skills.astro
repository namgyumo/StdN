---
import BaseLayout from '@layouts/BaseLayout.astro';
import BojWidget from '@components/BojWidget.astro';

const skills = [
  {
    icon: '[ C ]',
    name: 'C — Primary',
    desc: '주력 언어. io/lib 외의 자료구조·알고리즘은 가능하면 직접 구현하며 저수준 감각을 쌓고 있습니다. 포인터·메모리 레이아웃을 다루는 것에 익숙합니다.',
  },
  {
    icon: '[ C++ ]',
    name: 'C++ — Design Patterns',
    desc: '싱글턴·커맨드·팩토리 같은 설계 패턴을 실제 토이 프로젝트(노트 에디터)에 적용하면서 OOP 와 자원 관리 감각을 익히는 중입니다.',
  },
  {
    icon: '[ PY / JAVA ]',
    name: 'Python · Java — Sub',
    desc: 'Python 은 자동화·데이터 처리·PS 보조로, Java 는 OOP 개념 비교·학과 과제 구현용으로 사용합니다.',
  },
  {
    icon: '[ ALGORITHM ]',
    name: 'Data Structure & PS',
    desc: '시간/공간 복잡도를 고려한 알고리즘 설계. 최적의 로직으로 병목을 해결하는 것을 즐깁니다. BOJ 에서 꾸준히 연습 중.',
  },
  {
    icon: '[ TOOLS ]',
    name: 'Visual Studio · VSCode · Ubuntu',
    desc: '윈도우 네이티브 개발은 Visual Studio, 일반 편집과 리눅스 쪽은 VSCode + Ubuntu (WSL 포함) 로 나눠서 씁니다.',
  },
];

const records = [
  { date: '25.06.13', text: '교내 DoD 알고리즘 대회 우수상' },
  { date: '25.09.09', text: 'U-BDIA 코딩 테스트 참여' },
  { date: '25.09.11', text: 'GDGoC-DEU 멤버 참여' },
  { date: '25.10.11', text: 'ICPC 대회 참여' },
  { date: '26.02.20', text: 'GDGoC-DEU 코어 멤버 참여' },
  { date: '26.02.21', text: 'solved.ac Gold-V 달성' },
];
---

<BaseLayout
  title="Skills"
  description="std::N 이 다루는 기술과 지금까지 참여한 활동 기록."
>
  <section class="skills-hero">
    <h1 class="h1">Skills &amp; Experience</h1>
    <p class="section-sub">기술 및 역량</p>
  </section>

  <section class="container">
    <div class="skills-layout">
      <div class="skills-col">
        <h2 class="section-h1">SKILLS 기술</h2>
        <div class="skills-stack">
          {skills.map((s) => (
            <article class="skill-card">
              <div class="skill-icon">{s.icon}</div>
              <h3 class="skill-name">{s.name}</h3>
              <p class="skill-desc">{s.desc}</p>
            </article>
          ))}
        </div>
      </div>

      <div class="skills-col">
        <h2 class="section-h1">RECORDS 활동</h2>
        <ol class="records">
          {records.map((r) => (
            <li class="record">
              <time class="port-date" datetime={`20${r.date.replace(/\./g, '-')}`}>{r.date}</time>
              <div class="port-inner">{r.text}</div>
            </li>
          ))}
        </ol>
      </div>
    </div>

    <BojWidget />
  </section>
</BaseLayout>

<style>
  .skills-hero {
    text-align: center;
    padding: 40px 20px 0;
  }
  .skills-hero .h1 {
    display: inline-block;
  }
  .section-sub {
    margin-top: 10px;
    font-family: var(--font-mono);
    color: var(--color-fg-dim);
    letter-spacing: 3px;
  }
  .skills-col {
    display: flex;
    flex-direction: column;
  }
  .skills-stack {
    display: flex;
    flex-direction: column;
    gap: 30px;
    margin-top: 30px;
  }
  .skills-stack .skill-card {
    margin-top: 0;
  }
  .skills-col .records {
    margin-top: 30px;
  }
</style>
