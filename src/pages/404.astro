---
import BaseLayout from '@layouts/BaseLayout.astro';

function hex(n: number): string {
  return '0x' + Math.floor(Math.random() * 0xffffffff).toString(16).padStart(8, '0');
}
const addrs = Array.from({ length: 6 }, hex);
---

<BaseLayout title="404" description="Segmentation fault — 요청한 페이지를 찾을 수 없습니다." noindex>
  <div class="err-screen">
    <div class="err-code">SIGSEGV</div>
    <p class="err-line">
      <span class="label">[error]</span> segmentation fault<br />
      <span class="label">[errno]</span> <code>ENOENT (2): No such file or directory</code><br />
      <span class="label">[reason]</span> 요청한 리소스 <code>{Astro.url.pathname}</code> 는 존재하지 않거나 이전되었습니다.
    </p>

    <pre class="memdump" aria-hidden="true">
<code>
  {addrs.map((a) => `${a}  ${hex(1).slice(2)} ${hex(1).slice(2)} ${hex(1).slice(2)} ${hex(1).slice(2)}  .. segfault\n`).join('')}
</code>
    </pre>

    <div style="display: flex; gap: 12px; flex-wrap: wrap; justify-content: center;">
      <a class="btntext" href="/"><div class="box"><strong>→ Home</strong></div></a>
      <a class="btntext" href="/blog"><div class="contact-box"><strong>→ Blog</strong></div></a>
    </div>

    <p class="err-line" style="margin-top: 40px;">
      <span class="label">[hint]</span> 상단 네비 또는 <kbd>Ctrl/Cmd</kbd> + <kbd>K</kbd> 로 팔레트를 여세요.
    </p>
  </div>
</BaseLayout>

<style>
  .memdump {
    background: rgba(8, 8, 8, 0.8);
    border: 1px solid rgba(255, 0, 60, 0.3);
    border-radius: 8px;
    padding: 16px;
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--color-fg-dim);
    max-width: 520px;
    width: 100%;
    overflow-x: auto;
    white-space: pre;
    margin: 0;
  }
</style>
