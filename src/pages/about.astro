---
import BaseLayout from '@layouts/BaseLayout.astro';

const recommendedGames = [
  { href: 'https://namu.wiki/w/문명%206', title: '문명 VI', src: '/images/civilization.jpg' },
  { href: 'https://namu.wiki/w/명조:%20워더링%20웨이브', title: '명조: 워더링 웨이브', src: '/images/mw.jpg' },
  { href: 'https://namu.wiki/w/붕괴%3A%20스타레일', title: '붕괴: 스타레일', src: '/images/starrail.jpg' },
  { href: 'https://namu.wiki/w/하츠%20오브%20아이언%204', title: '하츠 오브 아이언 IV', src: '/images/iron.jpg' },
];

const recommendedMusicals = [
  { href: 'https://namu.wiki/w/오페라의%20유령(뮤지컬)', title: '오페라의 유령', src: '/images/opera.jpg' },
  { href: 'https://namu.wiki/w/하데스타운', title: '하데스타운', src: '/images/hadeth.jpg' },
  { href: 'https://namu.wiki/w/디어%20에반%20핸슨', title: '디어 에반 핸슨', src: '/images/evan.jpg' },
  { href: 'https://namu.wiki/w/위키드(뮤지컬)', title: '위키드', src: '/images/wicked.jpg' },
];

const values = [
  { title: 'VALUES', body: '저수준을 공부하고 직접 구현하는 걸 좋아합니다. 라이브러리에 의존하기 전에 "왜 이게 이렇게 동작하는가" 를 먼저 이해하려고 합니다. 성능과 효율도 같은 맥락에서 중시하고, 불필요한 리소스 낭비가 눈에 밟히는 편입니다.' },
  { title: 'GOALS', body: '시스템 엔지니어가 되는 게 장기 목표입니다. 졸업 후에도 화려한 프레임워크보다 OS·메모리·컴파일러·네트워크 같은 구조를 제대로 이해하는 개발자로 자리 잡는 것을 지향합니다.' },
  { title: 'MOTIVE', body: 'C 로 알고리즘 문제를 풀다가, 로직 하나 바꿨을 뿐인데 실행 시간이 눈에 띄게 달라지는 걸 보고 자료구조와 메모리에 빠졌습니다. 그 뒤로 가능하면 표준 io/lib 외에는 자료구조를 직접 구현하는 방식으로 연습하고 있습니다.' },
  { title: 'INTERESTS', body: '저수준·메모리·알고리즘·설계 패턴. 포인터로 데이터가 메모리에서 어떻게 움직이는지 추적하는 것, 그리고 C++ 로 싱글턴/커맨드/팩토리 같은 설계 패턴을 실제 프로젝트에 적용해보는 것을 즐깁니다.' },
];
---

<BaseLayout
  title="About"
  description="std::N 소개 — 동의대 컴퓨터소프트웨어공학과에서 알고리즘과 저수준 시스템을 공부하는 주니어 개발자."
>
  <section class="about-hero">
    <p class="typing">A Junior Developer Grounded in Basics</p>
    <h1 class="h1">기본이 탄탄한 주니어 개발자.</h1>
    <p class="h1" style="display:block; margin-top: 40px;">제가 누구냐고요?</p>

    <div class="mouse" aria-hidden="true">
      <div class="in-mouse"></div>
    </div>
    <p class="mouse-hint"><strong>scroll</strong></p>
  </section>

  <section class="container">
    <div class="about-box">
      <img src="/images/poby01.jpg" alt="프로필 사진" class="profile" width="150" height="150" />
      <div class="info">
        <div class="first-info">
          <p class="about-title">남규모 · namgyumo</p>
          <p class="about-value">2006.02.13 · Junior System Developer</p>
        </div>
        <div class="second-info">
          <p class="about-title">Dong-eui University</p>
          <p class="about-value">컴퓨터소프트웨어공학과 25학번 · 2학년</p>
        </div>
      </div>
    </div>

    {values.map((v) => (
      <div class="info-box">
        <div class="info-title-box"><h2>{v.title}</h2></div>
        <p>{v.body}</p>
      </div>
    ))}

    <div class="info-box">
      <div class="info-title-box"><h2>HOBBIES</h2></div>
      <p>평소 코딩 외의 시간에는 서브컬쳐 게임을 즐기거나 음악을 즐겨 듣습니다. 뮤지컬도 가끔 보러 갑니다.</p>

      <div style="margin-top: 40px;">
        <h3 class="rec-heading">std::N의 추천 게임</h3>
        <div class="rec-grid">
          {recommendedGames.map((g) => (
            <a href={g.href} target="_blank" rel="noopener noreferrer" class="rec-card" title={g.title}>
              <img src={g.src} alt={g.title} loading="lazy" width="150" height="150" />
            </a>
          ))}
        </div>
      </div>

      <div style="margin-top: 40px;">
        <h3 class="rec-heading">std::N의 추천 뮤지컬</h3>
        <div class="rec-grid">
          {recommendedMusicals.map((m) => (
            <a href={m.href} target="_blank" rel="noopener noreferrer" class="rec-card" title={m.title}>
              <img src={m.src} alt={m.title} loading="lazy" width="150" height="150" />
            </a>
          ))}
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .about-hero {
    text-align: center;
    padding: 0 20px;
  }
  .rec-heading {
    color: var(--color-fg);
    margin-bottom: 20px;
    font-weight: 400;
    letter-spacing: 1px;
  }
</style>
