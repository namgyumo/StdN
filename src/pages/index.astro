---
import BaseLayout from '@layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { formatShortDate } from '@lib/format';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.publishedAt.valueOf() - a.data.publishedAt.valueOf())
  .slice(0, 4);
---

<BaseLayout
  title={undefined}
  description="기본이 탄탄한 주니어 개발자. 알고리즘·자료구조·포인터에 관심이 많은 동의대 컴소공 학생의 홈페이지."
>
  <section class="home-hero">
    <p class="typing">A Junior Developer Grounded in Basics</p>
    <h1 class="h1">기본이 탄탄한 주니어 개발자.</h1>
    <p class="h2">
      알고리즘과 자료구조, 그리고 포인터에 관심이 많은 주니어 개발자입니다.
      <br /><br />
      기본에 충실하면서도, 코드가 실제로 어떻게 동작하는지를 이해하려는 개발자가 되고 싶습니다.
    </p>

    <div class="home-cta">
      <a href="/about" class="btntext">
        <div class="box"><strong>저에 대해 더 알아보세요</strong></div>
      </a>
      <a href="/contact" class="btntext">
        <div class="contact-box"><strong>저에게 연락하기</strong></div>
      </a>
    </div>

    <div class="sub-pro">
      <h2 class="h1 hh1">Hi, Welcome to std::N</h2>
      <p class="sub-inner">
        알고리즘과 자료구조에 관심이 많고, 포인터나 저수준 언어 쪽도 재미있게 공부하고 있습니다.<br />
        백준에서 문제 푸는 것도 좋아합니다.<br />
        새로운 네트워킹과 기회를 언제나 환영합니다.
      </p>
    </div>
  </section>

  {posts.length > 0 && (
    <section class="home-posts container container-narrow">
      <h2 class="section-h1">Recent Posts</h2>
      <ul class="post-list">
        {posts.map((p) => (
          <li>
            <a class="post-item" href={`/blog/${p.id}`}>
              <span class="post-date">{formatShortDate(p.data.publishedAt)}</span>
              <div>
                <h3 class="post-title">{p.data.title}</h3>
                {p.data.tags && p.data.tags.length > 0 && (
                  <div class="post-tags">
                    {p.data.tags.slice(0, 3).map((t: string) => <span class="tag">#{t}</span>)}
                  </div>
                )}
              </div>
            </a>
          </li>
        ))}
      </ul>
      <p style="text-align:center; margin-top: 24px;">
        <a href="/blog" class="btntext">→ 모든 글 보기</a>
      </p>
    </section>
  )}
</BaseLayout>

<style>
  .home-hero {
    text-align: center;
    padding: 0 20px;
    max-width: var(--container);
    margin: 0 auto;
  }
  .home-hero .h1 {
    display: inline-block;
    margin-top: 30px;
  }
  .home-cta {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 12px;
    margin-top: 100px;
  }
  .home-posts {
    margin-top: 140px;
  }
  .home-posts h2 {
    text-align: center;
    display: block;
  }
</style>
