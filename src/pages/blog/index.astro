---
import BaseLayout from '@layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { formatShortDate } from '@lib/format';

const all = (await getCollection('blog', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.publishedAt.valueOf() - a.data.publishedAt.valueOf(),
);

// 태그 집계
const tagCount = new Map<string, number>();
for (const p of all) {
  for (const t of p.data.tags) tagCount.set(t, (tagCount.get(t) ?? 0) + 1);
}
const tags = [...tagCount.entries()].sort((a, b) => b[1] - a[1]);
---

<BaseLayout
  title="Blog"
  description="std::N 의 글 모음 — 알고리즘, C/C++, 시스템 프로그래밍, 개발 일지."
>
  <section class="container container-narrow blog-index">
    <header class="blog-head">
      <h1 class="h1">Blog</h1>
      <p class="eyebrow">// archive</p>
      <p>총 <strong>{all.length}</strong>개의 글</p>
    </header>

    {tags.length > 0 && (
      <div class="tag-cloud">
        {tags.map(([t, c]) => (
          <a href={`/blog/tags/${encodeURIComponent(t)}`} class="tag">
            #{t} <span style="opacity:.6">{c}</span>
          </a>
        ))}
      </div>
    )}

    {all.length === 0 ? (
      <p class="empty">아직 공개된 글이 없습니다.</p>
    ) : (
      <ul class="post-list">
        {all.map((p) => (
          <li>
            <a class="post-item" href={`/blog/${p.id}`}>
              <span class="post-date">{formatShortDate(p.data.publishedAt)}</span>
              <div>
                <h2 class="post-title">{p.data.title}</h2>
                {p.data.description && <p class="post-excerpt">{p.data.description}</p>}
                {p.data.tags.length > 0 && (
                  <div class="post-tags">
                    {p.data.tags.map((t) => <span class="tag">#{t}</span>)}
                  </div>
                )}
              </div>
            </a>
          </li>
        ))}
      </ul>
    )}
  </section>
</BaseLayout>

<style>
  .blog-index { padding-top: 60px; }
  .blog-head { text-align: center; margin-bottom: 40px; }
  .blog-head .h1 { display: inline-block; }
  .blog-head p { margin-top: 10px; color: var(--color-fg-dim); font-family: var(--font-mono); }
  .tag-cloud {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    justify-content: center;
    margin: 20px 0 10px;
  }
  .post-excerpt {
    margin: 6px 0 0;
    color: var(--color-fg-dim);
    font-size: 0.9rem;
    line-height: 1.5;
  }
  .empty {
    text-align: center;
    padding: 60px 20px;
    color: var(--color-fg-dim);
    font-family: var(--font-mono);
  }
</style>
