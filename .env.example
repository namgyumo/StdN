# Public site URL (used for canonical, RSS, OG)
PUBLIC_SITE_URL=https://std-n.dev

# Giscus (댓글) — https://giscus.app 에서 발급
PUBLIC_GISCUS_REPO=namgyumo/std-n
PUBLIC_GISCUS_REPO_ID=
PUBLIC_GISCUS_CATEGORY=General
PUBLIC_GISCUS_CATEGORY_ID=

# Cloudflare Web Analytics (선택)
PUBLIC_CF_ANALYTICS_TOKEN=

# Resend API (contact 폼, 추후)
RESEND_API_KEY=

# ─────────────────────────────────────────────────────────────
# Cloudflare Pages 환경변수 (Dashboard → Settings → Environment variables)
# 로컬 .env 에는 보통 넣지 않고, Pages 프로젝트에 직접 등록.
# 프리뷰/프로덕션 둘 다 같은 값을 넣어야 admin/AI 기능이 동작.
# ─────────────────────────────────────────────────────────────

# Admin 로그인 비밀번호 해시 — PBKDF2 형식: "iterations:salt_hex:hash_hex"
# 생성 (로컬 터미널에서, YOUR_PASSWORD 를 원하는 비번으로 교체):
#   node -e "const c=require('crypto');const s=c.randomBytes(16).toString('hex');const it=100000;const h=c.pbkdf2Sync(process.argv[1],Buffer.from(s,'hex'),it,32,'sha256').toString('hex');console.log(\`\${it}:\${s}:\${h}\`)" 'YOUR_PASSWORD'
ADMIN_PASSWORD_HASH=

# 세션 쿠키 서명용 시크릿 (HMAC-SHA256 키, 최소 32바이트 랜덤 권장)
# 생성:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=

# Google AI Studio Gemini API 키 — https://aistudio.google.com/apikey
# admin 에디터의 AI 이어쓰기 / 다듬기 / 수정 기능에서 사용.
GEMINI_API_KEY=
